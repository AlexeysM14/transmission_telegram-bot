#!/usr/bin/env python3
from __future__ import annotations

import base64
import json
import os
import socket
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path
from typing import Optional
from urllib.error import HTTPError, URLError
from urllib.parse import urlsplit, urlunsplit
from urllib.request import ProxyHandler, Request, build_opener

ROOT = Path(__file__).resolve().parent
ENV_FILE = ROOT / ".env"
SERVICE_NAME = "transmission3-bot"
TELEGRAM_API_BASE = "https://api.telegram.org"
SUPPORTED_PROXY_SCHEMES = {"http", "https", "socks5", "socks5h"}


def run(cmd: list[str], *, check: bool = True) -> int:
    print(f"\n$ {' '.join(cmd)}")
    proc = subprocess.run(cmd, cwd=ROOT)
    if check and proc.returncode != 0:
        raise RuntimeError(f"Command failed: {' '.join(cmd)}")
    return proc.returncode


def run_capture(cmd: list[str]) -> tuple[int, str, str]:
    proc = subprocess.run(cmd, cwd=ROOT, capture_output=True, text=True)
    return proc.returncode, proc.stdout.strip(), proc.stderr.strip()


def load_env() -> dict[str, str]:
    data: dict[str, str] = {}
    if not ENV_FILE.exists():
        return data

    for line in ENV_FILE.read_text(encoding="utf-8").splitlines():
        raw = line.strip()
        if not raw or raw.startswith("#") or "=" not in raw:
            continue
        key, value = raw.split("=", 1)
        data[key.strip()] = value.strip().strip('"').strip("'")
    return data


def save_env(values: dict[str, str]) -> None:
    lines = [
        "# telegram bot settings",
        *(f"{k}={v}" for k, v in sorted(values.items())),
        "",
    ]
    ENV_FILE.write_text("\n".join(lines), encoding="utf-8")
    print(f"✅ Saved {ENV_FILE}")


def do_update_from_github() -> None:
    run(["git", "fetch", "--all"])
    run(["git", "pull", "--ff-only"])

    venv_python = ROOT / ".venv" / "bin" / "python"
    if venv_python.exists():
        run([str(venv_python), "-m", "pip", "install", "-r", "requirements.txt"])
    else:
        run([sys.executable, "-m", "pip", "install", "-r", "requirements.txt"])

    print("✅ Update complete.")


def restart_bot_service() -> None:
    cmd = ["systemctl", "restart", SERVICE_NAME]
    if os.geteuid() != 0:
        cmd = ["sudo", *cmd]

    run(cmd)
    print(f"✅ Service '{SERVICE_NAME}' restarted.")


def set_env_key(key: str, prompt: str, *, allow_empty_delete: bool = False) -> None:
    data = load_env()
    value = input(prompt).strip()
    if not value:
        if not allow_empty_delete:
            print("⚠️ Empty value, nothing changed")
            return
        if key in data:
            data.pop(key, None)
            save_env(data)
            print(f"✅ Removed {key} from {ENV_FILE}")
        else:
            print(f"⚠️ {key} is not set, nothing changed")
        return
    data[key] = value
    save_env(data)


def normalize_proxy_url_or_raise(raw_url: str, *, env_name: str) -> str:
    value = raw_url.strip()
    parts = urlsplit(value)
    scheme = parts.scheme.lower()
    if not scheme or not parts.netloc:
        raise ValueError(f"{env_name}: invalid proxy URL")

    if scheme == "mtproto":
        raise ValueError(
            f"{env_name}: MTProto proxies are not supported for Telegram Bot API; use http(s):// or socks5://"
        )

    if scheme not in SUPPORTED_PROXY_SCHEMES:
        supported = ", ".join(sorted(SUPPORTED_PROXY_SCHEMES))
        raise ValueError(f"{env_name}: unsupported proxy scheme '{scheme}', supported: {supported}")
    return value


def unset_env_key(key: str) -> None:
    data = load_env()
    if key in data:
        data.pop(key, None)
        save_env(data)
        print(f"✅ Removed {key} from {ENV_FILE}")
        return
    print(f"⚠️ {key} is not set, nothing changed")


def get_log_file_path() -> Path:
    env = load_env()
    raw = env.get("LOG_FILE", "bot-errors.log").strip()
    path = Path(raw).expanduser()
    if not path.is_absolute():
        path = ROOT / path
    return path


def print_last_log_lines(*, lines: int = 10) -> None:
    log_file = get_log_file_path()
    if not log_file.exists():
        print(f"⚠️ Log file does not exist yet: {log_file}")
        return

    content = log_file.read_text(encoding="utf-8", errors="replace").splitlines()
    tail = content[-lines:]
    print(f"\n=== Last {len(tail)} lines of {log_file} ===")
    for row in tail:
        print(row)


def mask_proxy_url(raw_url: Optional[str]) -> str:
    if not raw_url:
        return "direct"

    parts = urlsplit(raw_url)
    if "@" not in parts.netloc:
        return raw_url

    _, _, hostinfo = parts.netloc.rpartition("@")
    return urlunsplit((parts.scheme, f"***:***@{hostinfo}", parts.path, parts.query, parts.fragment))


def format_bool(value: bool) -> str:
    return "yes" if value else "no"


def format_dt(value: float) -> str:
    return datetime.fromtimestamp(value, tz=timezone.utc).astimezone().strftime("%Y-%m-%d %H:%M:%S %Z")


def build_proxy_handler(proxy_url: Optional[str]) -> ProxyHandler:
    if not proxy_url:
        return ProxyHandler({})
    return ProxyHandler({"http": proxy_url, "https": proxy_url})


def open_url(url: str, *, proxy_url: Optional[str], timeout: float, headers: Optional[dict[str, str]] = None, data: bytes | None = None) -> bytes:
    opener = build_opener(build_proxy_handler(proxy_url))
    request = Request(url, data=data, headers=headers or {})
    with opener.open(request, timeout=timeout) as response:
        return response.read()


def parse_timeout(raw: str) -> float:
    try:
        timeout = float((raw or "10").strip())
    except ValueError:
        return 10.0
    return timeout if timeout > 0 else 10.0


def build_transmission_url(env: dict[str, str]) -> str:
    explicit = env.get("TR_URL", "").strip()
    if explicit:
        return explicit

    protocol = env.get("TR_PROTOCOL", "http").strip() or "http"
    host = env.get("TR_HOST", "127.0.0.1").strip() or "127.0.0.1"
    port = env.get("TR_PORT", "9091").strip() or "9091"
    path = env.get("TR_PATH", "/transmission/rpc").strip() or "/transmission/rpc"
    if not path.startswith("/"):
        path = f"/{path}"
    return f"{protocol}://{host}:{port}{path}"


def build_basic_auth(user: Optional[str], password: Optional[str]) -> Optional[str]:
    if not user:
        return None
    token = base64.b64encode(f"{user}:{password or ''}".encode("utf-8")).decode("ascii")
    return f"Basic {token}"


def check_transmission_rpc(env: dict[str, str]) -> tuple[bool, str]:
    url = build_transmission_url(env)
    timeout = parse_timeout(env.get("TR_TIMEOUT", "10"))
    headers = {"Content-Type": "application/json"}
    auth = build_basic_auth(env.get("TR_USER"), env.get("TR_PASS"))
    if auth:
        headers["Authorization"] = auth

    payload = json.dumps({"method": "session-stats"}).encode("utf-8")
    try:
        open_url(url, proxy_url=None, timeout=timeout, headers=headers, data=payload)
    except HTTPError as exc:
        if exc.code != 409:
            return False, f"error: HTTP {exc.code}"
        session_id = exc.headers.get("X-Transmission-Session-Id", "").strip()
        if not session_id:
            return False, "error: missing X-Transmission-Session-Id"
        headers["X-Transmission-Session-Id"] = session_id
        try:
            response = open_url(url, proxy_url=None, timeout=timeout, headers=headers, data=payload)
        except HTTPError as retry_exc:
            return False, f"error: HTTP {retry_exc.code}"
        except URLError as retry_exc:
            return False, f"error: {retry_exc.reason}"
    except URLError as exc:
        return False, f"error: {exc.reason}"
    except OSError as exc:
        return False, f"error: {exc}"
    else:
        return False, "error: unexpected response without session handshake"

    try:
        body = json.loads(response.decode("utf-8"))
        arguments = body.get("arguments", {})
        active = arguments.get("activeTorrentCount", 0)
        paused = arguments.get("pausedTorrentCount", 0)
        total = arguments.get("torrentCount", 0)
        down = arguments.get("downloadSpeed", 0)
        up = arguments.get("uploadSpeed", 0)
        return True, f"ok: torrents={total}, active={active}, paused={paused}, down={down} B/s, up={up} B/s"
    except (ValueError, TypeError, AttributeError) as exc:
        return False, f"error: invalid JSON response ({exc})"


def check_telegram_api(token: str, *, proxy_url: Optional[str], timeout: float, label: str) -> tuple[bool, str]:
    target = f"{TELEGRAM_API_BASE}/bot{token}/getMe"
    try:
        body = open_url(target, proxy_url=proxy_url, timeout=timeout)
        payload = json.loads(body.decode("utf-8"))
    except HTTPError as exc:
        return False, f"{label}: HTTP {exc.code}"
    except URLError as exc:
        return False, f"{label}: {exc.reason}"
    except OSError as exc:
        return False, f"{label}: {exc}"
    except ValueError as exc:
        return False, f"{label}: invalid JSON ({exc})"

    if not payload.get("ok"):
        description = str(payload.get("description", "unknown error"))
        return False, f"{label}: API error: {description}"

    result = payload.get("result") or {}
    username = result.get("username") or "unknown"
    return True, f"{label}: ok (@{username})"


def check_tcp_target(raw_url: str, *, timeout: float, label: str) -> tuple[bool, str]:
    parts = urlsplit(raw_url)
    host = parts.hostname
    port = parts.port
    if not host or port is None:
        return False, f"{label}: invalid URL"

    try:
        with socket.create_connection((host, port), timeout=timeout):
            return True, f"{label}: tcp ok ({host}:{port})"
    except OSError as exc:
        return False, f"{label}: tcp error: {exc}"


def print_status() -> int:
    env = load_env()
    timeout = parse_timeout(env.get("TR_TIMEOUT", "10"))
    tg_token = env.get("TG_TOKEN", "").strip()
    tg_proxy = env.get("TG_PROXY", "").strip() or None
    tg_updates_proxy = env.get("TG_GET_UPDATES_PROXY", "").strip() or None
    effective_updates_proxy = tg_updates_proxy or tg_proxy
    log_file = get_log_file_path()
    venv_python = ROOT / ".venv" / "bin" / "python"

    print("=== transmission3-bot status ===")
    print(f"root: {ROOT}")
    print(f"env file: {ENV_FILE} ({'present' if ENV_FILE.exists() else 'missing'})")
    print(f"venv python: {venv_python} ({'present' if venv_python.exists() else 'missing'})")
    print(f"log file: {log_file} ({'present' if log_file.exists() else 'missing'})")
    if log_file.exists():
        stat = log_file.stat()
        print(f"  size: {stat.st_size} bytes")
        print(f"  modified: {format_dt(stat.st_mtime)}")

    print("\n[configuration]")
    print(f"TG_TOKEN configured: {format_bool(bool(tg_token))}")
    print(f"TG_PROXY: {mask_proxy_url(tg_proxy)}")
    print(f"TG_GET_UPDATES_PROXY: {mask_proxy_url(tg_updates_proxy)}")
    print(f"effective getUpdates proxy: {mask_proxy_url(effective_updates_proxy)}")
    print(f"Transmission RPC URL: {build_transmission_url(env)}")
    print(f"TR_TIMEOUT: {timeout:g}s")

    print("\n[systemd]")
    service_ok = True
    for field, command in (
        ("active", ["systemctl", "is-active", SERVICE_NAME]),
        ("enabled", ["systemctl", "is-enabled", SERVICE_NAME]),
    ):
        code, out, err = run_capture(command)
        value = out or err or f"exit {code}"
        print(f"{field}: {value}")
        if code != 0 and field == "active":
            service_ok = False

    code, out, err = run_capture(["systemctl", "show", SERVICE_NAME, "--property=MainPID,ExecMainStatus,ExecMainStartTimestamp,FragmentPath"])
    if code == 0:
        for line in out.splitlines():
            if line:
                print(line)
    else:
        print(f"details: {err or out or f'exit {code}'}")
        service_ok = False

    print("\n[checks]")
    overall_ok = service_ok

    tr_ok, tr_message = check_transmission_rpc(env)
    print(f"Transmission RPC: {tr_message}")
    overall_ok = overall_ok and tr_ok

    if tg_proxy:
        tcp_ok, tcp_message = check_tcp_target(tg_proxy, timeout=timeout, label="TG_PROXY")
        print(f"Proxy socket: {tcp_message}")
        overall_ok = overall_ok and tcp_ok
    else:
        print("Proxy socket: TG_PROXY not configured (direct connection)")

    if tg_updates_proxy and tg_updates_proxy != tg_proxy:
        upd_tcp_ok, upd_tcp_message = check_tcp_target(tg_updates_proxy, timeout=timeout, label="TG_GET_UPDATES_PROXY")
        print(f"Updates proxy socket: {upd_tcp_message}")
        overall_ok = overall_ok and upd_tcp_ok

    if tg_token:
        bot_ok, bot_message = check_telegram_api(tg_token, proxy_url=tg_proxy, timeout=timeout, label="Telegram Bot API")
        print(bot_message)
        overall_ok = overall_ok and bot_ok

        if effective_updates_proxy != tg_proxy:
            upd_ok, upd_message = check_telegram_api(
                tg_token,
                proxy_url=effective_updates_proxy,
                timeout=timeout,
                label="Telegram getUpdates path",
            )
            print(upd_message)
            overall_ok = overall_ok and upd_ok
    else:
        print("Telegram Bot API: skipped (TG_TOKEN is not configured)")

    print("\n[result]")
    print("overall status: OK" if overall_ok else "overall status: NEEDS ATTENTION")
    return 0 if overall_ok else 1


def menu() -> None:
    while True:
        print(
            "\n=== transmission3-bot update ===\n"
            "1) Download updates from GitHub\n"
            "2) Set Telegram bot token (TG_TOKEN)\n"
            "3) Set Telegram allowed user id(s) (ALLOWED_USER_IDS)\n"
            "4) Set Telegram proxy URL (TG_PROXY, example: http://login:password@127.0.0.1:8080)\n"
            "5) Set Telegram getUpdates proxy URL (TG_GET_UPDATES_PROXY, optional)\n"
            "6) Set Transmission RPC URL (TR_URL, example: http://127.0.0.1:9091/transmission/rpc)\n"
            "7) Restart bot service\n"
            "8) Show last 10 lines from bot error log (показать последние 10 строк логов)\n"
            "9) Disable Telegram proxy (remove TG_PROXY)\n"
            "10) Disable Telegram getUpdates proxy override (remove TG_GET_UPDATES_PROXY)\n"
            "0) Exit\n"
        )

        choice = input("Select an action: ").strip()

        try:
            if choice == "1":
                do_update_from_github()
            elif choice == "2":
                set_env_key("TG_TOKEN", "Enter Telegram token: ")
            elif choice == "3":
                set_env_key(
                    "ALLOWED_USER_IDS",
                    "Enter user id(s), comma-separated (leave empty to remove restriction): ",
                    allow_empty_delete=True,
                )
            elif choice == "4":
                data = load_env()
                value = input(
                    "Enter Telegram proxy URL (leave empty to disable proxy; supported: http(s):// or socks5://): "
                ).strip()
                if not value:
                    data.pop("TG_PROXY", None)
                    save_env(data)
                    print(f"✅ Removed TG_PROXY from {ENV_FILE}")
                else:
                    data["TG_PROXY"] = normalize_proxy_url_or_raise(value, env_name="TG_PROXY")
                    save_env(data)
            elif choice == "5":
                data = load_env()
                value = input(
                    "Enter Telegram getUpdates proxy URL (leave empty to reuse TG_PROXY; supported: http(s):// or socks5://): "
                ).strip()
                if not value:
                    data.pop("TG_GET_UPDATES_PROXY", None)
                    save_env(data)
                    print(f"✅ Removed TG_GET_UPDATES_PROXY from {ENV_FILE}")
                else:
                    data["TG_GET_UPDATES_PROXY"] = normalize_proxy_url_or_raise(value, env_name="TG_GET_UPDATES_PROXY")
                    save_env(data)
            elif choice == "6":
                set_env_key(
                    "TR_URL",
                    "Enter Transmission RPC URL (leave empty to use TR_PROTOCOL/TR_HOST/TR_PORT/TR_PATH): ",
                    allow_empty_delete=True,
                )
            elif choice == "7":
                restart_bot_service()
            elif choice == "8":
                print_last_log_lines(lines=10)
            elif choice == "9":
                unset_env_key("TG_PROXY")
            elif choice == "10":
                unset_env_key("TG_GET_UPDATES_PROXY")
            elif choice == "0":
                print("Bye")
                return
            else:
                print("❌ Unknown item")
        except Exception as exc:
            print(f"❌ {exc}")


def main() -> int:
    if len(sys.argv) == 2 and sys.argv[1] == "update":
        menu()
        return 0
    if len(sys.argv) == 2 and sys.argv[1] == "status":
        return print_status()

    print("Usage: transmission3-bot update|status")
    return 1


if __name__ == "__main__":
    raise SystemExit(main())
